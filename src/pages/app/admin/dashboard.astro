---
import { authenticateAdmin, type Store } from '../../utils';

// Example of server-side authentication check
// In a real app, you'd get this from session/database
const exampleStore: Store = {
  id: 'demo-store',
  domain: 'demo-shop.myshopify.com',
  plan: 'starter', // Set to null or empty to test redirect
  onboarded: true
};

// Perform authentication check
const authResult = authenticateAdmin(exampleStore);

// Handle server-side redirect
if (typeof authResult === 'object' && !authResult.success && authResult.redirect) {
  return Astro.redirect(authResult.redirect.destination);
}
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin Dashboard - EasyEdit</title>
</head>
<body>
  <main class="container mx-auto p-8">
    <h1 class="text-3xl font-bold mb-6">Admin Dashboard</h1>
    
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6">
      ✅ Authentication successful! Store plan: {exampleStore.plan}
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white p-6 rounded-lg shadow">
        <h2 class="text-xl font-semibold mb-4">Store Information</h2>
        <p><strong>Store ID:</strong> {exampleStore.id}</p>
        <p><strong>Domain:</strong> {exampleStore.domain}</p>
        <p><strong>Plan:</strong> {exampleStore.plan}</p>
        <p><strong>Onboarded:</strong> {exampleStore.onboarded ? 'Yes' : 'No'}</p>
      </div>
      
      <div class="bg-white p-6 rounded-lg shadow">
        <h2 class="text-xl font-semibold mb-4">Quick Actions</h2>
        <div class="space-y-2">
          <button class="w-full bg-blue-500 text-white py-2 px-4 rounded hover:bg-blue-600">
            View Analytics
          </button>
          <button class="w-full bg-green-500 text-white py-2 px-4 rounded hover:bg-green-600">
            Manage Orders
          </button>
          <button class="w-full bg-purple-500 text-white py-2 px-4 rounded hover:bg-purple-600">
            Settings
          </button>
        </div>
      </div>
      
      <div class="bg-white p-6 rounded-lg shadow">
        <h2 class="text-xl font-semibold mb-4">Plan Status</h2>
        <p class="text-sm text-gray-600 mb-4">
          Your current plan provides access to all admin features.
        </p>
        <a href="/app/plans" class="text-blue-500 hover:underline">
          Upgrade Plan
        </a>
      </div>
    </div>
  </main>

  <script>
    // Client-side authentication example
    import { authenticateAdmin } from '../../utils';
    
    // Example of client-side re-authentication check
    document.addEventListener('DOMContentLoaded', () => {
      // This would typically come from your app's state/session
      const currentStore = {
        id: 'demo-store',
        plan: 'starter',
        onboarded: true
      };
      
      // Perform client-side authentication check
      const isAuthenticated = authenticateAdmin(currentStore);
      
      if (!isAuthenticated) {
        console.log('Client-side authentication failed, redirecting...');
        // The authenticateAdmin function will handle the redirect
      }
    });
  </script>
</body>
</html>